[Desktop Entry]
Version=1.0
Type=Application
Name=Install BEACN Utility
Comment=Installs the BEACN Utility application for Linux
Icon=system-software-install
Terminal=false
Exec=sh -c 'f=$(mktemp /tmp/beacn-XXXXXX.sh) && curl -fsSL https://beacn-on-linux.github.io/beacn-utility-repo/scripts/install-new.sh -o "$f" && _DESKTOP_LAUNCH=1 bash "$f"; rm -f "$f"'
Categories=System;
SingleMainWindow=true
