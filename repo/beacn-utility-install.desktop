[Desktop Entry]
Version=1.0
Type=Application
Name=Install BEACN Utility
Comment=Installs the BEACN Utility application for Linux
Icon=system-software-install
Terminal=true
Exec=sh -c 'curl -fsSL https://beacn-on-linux.github.io/beacn-utility-repo/scripts/install-new.sh | _DESKTOP_LAUNCH=1 bash'
Categories=System;
SingleMainWindow=true
